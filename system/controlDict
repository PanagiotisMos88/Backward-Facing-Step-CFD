FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     foamRun;

solver          incompressibleFluid;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         2000;

deltaT          1;

writeControl    timeStep;

writeInterval   500;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
   
     wallShearStressLower
    {
        type            wallShearStress;
        libs ("libfieldFunctionObjects.so");

        patches         (lowerWall);

        writePrecision  8;
        writeToFile     true;
        log             true;

        executeControl  timeStep;
        executeInterval 1;

        writeControl    timeStep;
        writeInterval   1;
    }
    
     yPlus
    {
        type            yPlus;
        libs            ("libfieldFunctionObjects.so");

         patches         (lowerWall);

        writePrecision  8;
        writeToFile     true;
        log             true;

        executeControl  timeStep;
        executeInterval 1;

        writeControl    timeStep;
        writeInterval   1;
    }
}
}



